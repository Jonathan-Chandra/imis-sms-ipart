# Authentication
VITE_AUTH_MODE=local
VITE_AUTH_URL=
VITE_AUTH_USERNAME=
VITE_AUTH_PASSWORD=

# API
VITE_API_URL=
VITE_IMIS_BASE_URL=

# App metadata
VITE_APP_NAME=ipart-template
VITE_APP_VERSION=0.1.0

# iMIS Query names — set to the query name as configured in iMIS Query Manager
VITE_IMIS_DYNAMIC_GROUP_LOOKUP_QUERY=
VITE_IMIS_ASSOCIATION_LOOKUP_QUERY=
VITE_IMIS_COMMITTEE_LOOKUP_QUERY=
VITE_IMIS_COMMITTEE_NAME_LOOKUP_QUERY=
VITE_IMIS_COMMITTEE_POSITION_LOOKUP_QUERY=
VITE_IMIS_OFFICE_LOOKUP_QUERY=
VITE_IMIS_MEMBER_LOOKUP_QUERY=
VITE_IMIS_STATE_LOOKUP_QUERY=
VITE_IMIS_GET_LOGGED_IN_USER=

# SMS dispatch queries — set to the query names used to fetch recipient lists
VITE_IMIS_SMS_MEMBER_GROUP_QUERY=
VITE_IMIS_SMS_COMMITTEE_GROUP_QUERY=
VITE_IMIS_SMS_DYNAMIC_GROUP_QUERY=

# Airflow (if applicable)
VITE_AIRFLOW_BASE_URL=
VITE_AIRFLOW_USERNAME=
VITE_AIRFLOW_PASSWORD=
